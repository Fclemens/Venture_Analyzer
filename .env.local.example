# ─── Clerk Authentication ────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk redirect URLs (leave as-is unless you change the route structure)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Encryption key for stored API keys ──────────────────────────────────────
# Generate with:  openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes = AES-256)
ENCRYPTION_KEY=your_64_char_hex_string_here
